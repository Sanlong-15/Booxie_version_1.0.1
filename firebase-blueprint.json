{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "birthday": { "type": "string" },
        "gender": { "type": "string" },
        "photoURL": { "type": "string" },
        "studentIdImage": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "rewardPoints": { "type": "number" },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Book": {
      "title": "Book",
      "description": "Book listing information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "condition": { "type": "string" },
        "type": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerId": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "sold"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "price", "sellerId"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Chat metadata",
      "type": "object",
      "properties": {
        "bookTitle": { "type": "string" },
        "bookId": { "type": "string" },
        "isAi": { "type": "boolean" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "participants": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Individual chat message",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "createdAt"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "A post in the community hub",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "comments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "authorId": { "type": "string" },
              "authorName": { "type": "string" },
              "content": { "type": "string" },
              "createdAt": { "type": "string" }
            }
          } 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Book listings"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/communityPosts/{postId}": {
      "schema": "CommunityPost",
      "description": "Community hub posts"
    }
  }
}
